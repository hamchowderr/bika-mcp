{
  "buildCommand": "echo 'Skipping build - Vercel compiles TypeScript automatically'",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/server"
    }
  ],
  "functions": {
    "api/server.ts": {
      "maxDuration": 60,
      "includeFiles": "bika-docs/**/*.md"
    }
  }
}
