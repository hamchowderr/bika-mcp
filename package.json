{
  "name": "bika-mcp",
  "version": "0.1.0",
  "description": "Model Context Protocol server for Bika.ai",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "bika-mcp": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "node -e \"console.log('Compiling TypeScript...')\" && tsc && node -e \"require('fs').chmodSync('dist/index.js', '755')\" && node -e \"console.log('✓ Build completed successfully!')\"",
    "dev": "tsc --watch",
    "dev:http": "node dist/http-server.js",
    "dev:vercel": "vercel dev",
    "start": "node dist/index.js",
    "inspector": "npx @modelcontextprotocol/inspector dist/index.js",
    "clean": "rimraf dist"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "bika",
    "bika.ai"
  ],
  "author": "hamchowderr",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.22.0",
    "@vercel/node": "^5.5.6",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.18.0",
    "mcp-handler": "^1.0.3",
    "zod": "^3.24.2",
    "zod-to-json-schema": "^3.23.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "rimraf": "^5.0.0",
    "typescript": "^5.0.0"
  }
}
